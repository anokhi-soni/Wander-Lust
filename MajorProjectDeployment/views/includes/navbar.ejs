<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navbar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- <link rel="stylesheet" href="styling.css"> -->
</head>
<body>
    <nav class="navbar navbar-expand-md bg-body-tertiary border-bottom sticky-top"> <!-- 'navbar-expand-lg' => this keeps the navbar expanded for large screen only, and for rest of the cases, it'll contract the nave bar. But we want our navbar to remain expanded on medium screen as well, so we'll wrote 'navbar-expand-md' instead of 'navbar-expand-lg'-->
        <div class="container-fluid">
            <!-- logo of our WandarLust Website -->
            <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
            
            <!-- screen collapse hone pe toggle button display honi chahiye isisliye  -->
            <button class="navbar-toggler" type="button" data-bs-toggzle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <!-- All the nav bar elements are here in this container -->
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
                <div class="navbar-nav">
                    <a class="nav-link" href="/listings">Explore</a> <!-- To see all the listings -->
                    
                    <!-- <a class="nav-link disabled" aria-disabled="true">Disabled</a> -->
                </div>

                <div class="SearchOption">
                    <form class="d-flex" role="search" method="get" action="http://localhost:3000/search">
                        <input class="form-control me-2 searchInp" name="destination" type="search" placeholder="Search destinations " aria-label="Search"/>
                        <button class="btn btn-outline-success searchBtn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
                    </form>
                </div>

                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/listings/add">Airbnb your home</a>

                    <% if(!userLoginInfo){ %> <!--agar userLoginInfo khaali hai, to matlab wo logged out hai, so yaa to wo existing id se login karega yaa to wo new id create karega-->
                        <a class="nav-link active signInLogIn" aria-current="page" href="/signup"><b>Sign up</b></a>
                        <a class="nav-link signInLogIn" href="/login"><b>Log in</b></a> <!-- To see all the listings -->
                    <% } else { %>
                        <a class="nav-link signInLogIn" href="/logout"><b>Log out</b></a>
                    <% } %>   
                    <!-- <a class="nav-link disabled" aria-disabled="true">Disabled</a> -->
                </div>

            </div>
        </div>
    </nav>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>